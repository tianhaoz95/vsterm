{
  "name": "nano-vsterm",
  "displayName": "nano-vsterm",
  "description": "Local terminal for vscode.dev via a local daemon",
  "version": "0.1.4",
  "publisher": "tianhaoz",
  "engines": { "vscode": "^1.82.0" },
  "repository": { "type": "git", "url": "https://github.com/tianhaoz95/vsterm.git" },
  "license": "MIT",
  "categories": ["Other"],
  "activationEvents": ["onCommand:nano-vsterm.open"],
  "browser": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nano-vsterm.open",
        "title": "Open Local Terminal",
        "category": "nano-vsterm"
      }
    ]
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies",
    "package:legacy": "npm run build && node scripts/package-legacy.js",
    "serve": "npm run build:dev && npx @vscode/test-web --extensionDevelopmentPath=$PWD --port 5000 --browser none",
    "test": "jest"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.2.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "ts-loader": "^9.4.0",
    "copy-webpack-plugin": "^11.0.0"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/src/__mocks__/vscode.ts"
    }
  }
}
